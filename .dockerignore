# Security: Prevent sensitive files from being copied into Docker images (S5996)
# Only exclude files that should NEVER be in production images

# Secrets and credentials - CRITICAL exclusions
.env
.env.local
.env.development
.env.production
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets
.npmrc
.yarnrc

# Git internals
.git
.gitignore
.gitattributes

# Development dependencies (will be rebuilt in container)
node_modules

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# Local development only
.replit
replit.nix
.upm/
.cache/
.local/

# Desktop/Mobile builds (not needed in server container)
electron/dist/
dist-electron/
out/
ios/
android/
# Tauri desktop app: source + Rust build artifacts (~1.1 GB of target/).
# The web server never imports from here.
src-tauri/

# Python ML libs are managed by uv (pyproject.toml + uv.lock) and rebuilt
# inside the deployment container via `uv sync`. The on-disk install is a
# redundant ~950 MB that should not ship in the image.
.pythonlibs/
.venv/

# Mockup-sandbox / canvas tooling — development only, not served in prod.
artifacts/

# Generated code dumps and report exports — not needed at runtime.
exports/
code-export/
installer-review-bundle/

# Project documentation — not needed in the runtime image.
docs/

# Unbundled source assets: vite inlines/hashes everything it imports into
# dist/ at build time, so the raw folder is not required at runtime.
attached_assets/

# Code quality tools working directories
.scannerwork/
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.temp
