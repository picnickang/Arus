# Security: Prevent sensitive files from being copied into Docker images (S5996)
# Only exclude files that should NEVER be in production images

# Secrets and credentials - CRITICAL exclusions
.env
.env.local
.env.development
.env.production
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets
.npmrc
.yarnrc

# Git internals
.git
.gitignore
.gitattributes

# Development dependencies (will be rebuilt in container)
node_modules

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.sublime-*

# Local development only
.replit
replit.nix
.upm/
.cache/

# Desktop/Mobile builds (not needed in server container)
electron/dist/
dist-electron/
out/
ios/
android/

# Code quality tools working directories
.scannerwork/
coverage/
.nyc_output/

# OS files
.DS_Store
Thumbs.db

# Temp files
*.tmp
*.temp
