#!/bin/sh
# Pre-commit hook for code quality checks
#
# Strategy:
#   1. lint-staged formats + ESLint-fixes ONLY staged files (fast)
#   2. fast guardrail scripts run on the whole repo (each <1s)
#
# To enable in a fresh clone:  git config core.hooksPath .husky
# To bypass (use sparingly):    git commit --no-verify

set -e

echo "Running lint-staged on staged files..."
npx lint-staged

echo "Running fast convergence guards..."
node scripts/check-storage-imports.mjs
node scripts/check-route-registration.mjs

echo "Pre-commit checks passed."
