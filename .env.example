# ─────────────────────────────────────────────────────────
# ARUS Marine PdM — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
SESSION_SECRET=           # Required in production — generate with: openssl rand -base64 32

# ── Database (pick ONE mode) ─────────────────────────────
# Cloud PostgreSQL (default)
DATABASE_URL=postgresql://user:password@host:5432/arus

# Neon serverless (alternative)
# NEON_DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/arus?sslmode=require

# Turso / libSQL (vessel offline mode)
# TURSO_DB_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-turso-token
# TURSO_SYNC_URL=                       # Optional — remote sync URL

# Deployment mode: CLOUD or VESSEL
DEPLOYMENT_MODE=CLOUD
# LOCAL_MODE=true                        # Set for offline/vessel operation
# EMBEDDED_MODE=true                     # Tauri desktop embedded mode

# ── AI / LLM ────────────────────────────────────────────
OPENAI_API_KEY=           # Required for AI copilot, reports, PdM analysis
# ANTHROPIC_API_KEY=      # Optional — fallback LLM provider

# ── Redis (optional — falls back to in-memory) ──────────
# REDIS_URL=redis://localhost:6379
# DISABLE_REDIS=true                     # Force in-memory cache

# ── Security ─────────────────────────────────────────────

# Setup/auth hardening
# Required to complete setup remotely; local/Tauri setup can still run without it.
SETUP_TOKEN=
# Restrict browser origins in production, e.g. https://your-repl-name.replit.app
ALLOWED_ORIGINS=
# Number of trusted reverse-proxy hops. Use 1 for Replit/proxy edge; leave unset for local vessel mode.
TRUST_PROXY_HOPS=1
# Legacy JSON-body HMAC fallback is disabled unless explicitly needed during device migration.
ALLOW_LEGACY_HMAC=false

# ENCRYPTION_KEY=                        # For sensitive data at rest — openssl rand -base64 32
# HMAC_SECRET=                           # Edge device authentication

# ── Aquametro FMCC Integration (optional) ────────────────
# FMCC_ENABLED=true
# FMCC_PROTOCOL=rest                     # rest | modbus
# FMCC_API_URL=https://your-fmcc-endpoint/api
# FMCC_API_KEY=
# FMCC_USERNAME=
# FMCC_PASSWORD=
# FMCC_VESSEL_ID=default-vessel
# FMCC_ORG_ID=default-org-id
# FMCC_POLLING_INTERVAL_MS=60000
# FMCC_TIMEOUT_MS=10000
# FMCC_RETRY_ATTEMPTS=3
# FMCC_RETRY_DELAY_MS=1000
# FMCC_USE_MOCK=false
# FMCC_MODBUS_HOST=localhost
# FMCC_MODBUS_PORT=502
# FMCC_MODBUS_UNIT_ID=1

# ── Telemetry Tuning (optional) ─────────────────────────
# TELEMETRY_BATCH_INTERVAL_MS=500
# TELEMETRY_MAX_BUFFER_SIZE=10000
# TELEMETRY_EVICTION_PERCENT=0.1
# TELEMETRY_MAX_RETRIES=3

# ── RUL Engine Flags (all default to true) ──────────────
# RUL_MODE_AWARE=true
# RUL_QUALITY_SCORING=true
# RUL_REPAIR_CENSORING=true
# RUL_CALIBRATION=true

# ── Scheduler Tuning (optional) ─────────────────────────
# SCHED_RUL_DAYS_CRITICAL=9
# SCHED_RISK_REPLAN_LEVEL=high
# SCHED_AUTO_REPLAN_DAYS=7

# ── Performance / Debug (optional) ──────────────────────
# PERF_DEBUG=false
# SLOW_REQUEST_THRESHOLD_MS=200
# DEBUG_EVENTS=false                     # Log domain event bus traffic
# TF_CPP_MIN_LOG_LEVEL=2                # Suppress TensorFlow warnings
# LOG_LEVEL=info

# ── Background Jobs (optional) ──────────────────────────
# DISABLE_JOB_QUEUE=false               # Disable job queue processing

# ── Email Notifications (optional) ──────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@arus.io
# SendGrid Signed Event Webhook verification key (ECDSA public key from the
# SendGrid Mail Settings → Event Webhook page). The /api/webhooks/sendgrid/events
# receiver is FAIL-CLOSED: when this is unset every webhook request is rejected.
# SENDGRID_WEBHOOK_VERIFICATION_KEY=

# ── Monitoring (optional) ───────────────────────────────
# GRAFANA_PASSWORD=
# ENABLE_MONITORING=true
# ENABLE_AI_FEATURES=true
# ENABLE_TELEMETRY=true
