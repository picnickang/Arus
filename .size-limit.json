[
  {
    "name": "Initial app bundle (entry + critical vendor chunks, gzip)",
    "path": [
      "dist/public/assets/app-*.js",
      "dist/public/assets/vendor-react-*.js",
      "dist/public/assets/vendor-ui-*.js"
    ],
    "limit": "300 KB",
    "gzip": true
  },
  {
    "name": "Heaviest lazy chunk: vendor-export (jspdf/xlsx/html2canvas/pdf-lib)",
    "path": "dist/public/assets/vendor-export-*.js",
    "limit": "320 KB",
    "gzip": true
  },
  {
    "name": "Heaviest lazy chunk: vendor-charts (recharts/d3)",
    "path": "dist/public/assets/vendor-charts-*.js",
    "limit": "150 KB",
    "gzip": true
  },
  {
    "name": "Total client JS (all chunks combined, gzip)",
    "path": "dist/public/assets/*.js",
    "limit": "1.95 MB",
    "gzip": true
  }
]
