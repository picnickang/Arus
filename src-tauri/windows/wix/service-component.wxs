<?xml version="1.0" encoding="UTF-8"?>
<!--
  ARUS Backend Windows Service — WiX fragment
  Advanced service-mode fragment. Do not merge this into the default
  tauri.conf.json desktop installer; use a separate service installer config.

  PATHS: $(var.SourceDir) in Tauri's WiX context resolves to the generated
  WiX working directory inside target/release/bundle/wix/, NOT the project
  root.  The CI workflow pre-stages nssm.exe and arus-server.exe into
  that directory under a resources/ subdirectory before tauri build runs,
  so Source= attributes use $(var.SourceDir)resources\ which is guaranteed
  to exist.  See the "Stage WiX resources" step in tauri-build.yml.

  UPGRADE: Custom actions check the Installed property.  On upgrade
  the service is stopped, files are replaced, database is migrated,
  and the service is restarted.  Fresh installs register and start.
  Uninstalls stop then remove.

  SERVICE ACCOUNT: Service runs under a dedicated local account "ARUS_svc"
  with a random 24-character password generated at install time.
  The account has no interactive logon rights and only write access
  to the ProgramData directory.

  TWO INSTALLER VARIANTS: The WebView2 install mode is controlled in
  tauri.conf.json — vessel builds use offlineInstaller (bundled, air-gap
  safe), cloud builds use downloadBootstrapper.  Both use this same fragment.
-->
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi"
     xmlns:util="http://schemas.microsoft.com/wix/UtilExtension">

  <Fragment>

    <DirectoryRef Id="APPLICATIONFOLDER">
      <Directory Id="ARUSBINDIR" Name="bin" />
    </DirectoryRef>

    <DirectoryRef Id="ARUSBINDIR">
      <Component Id="ARUSBackendBinaries"
                 Guid="A1B2C3D4-E5F6-7890-ABCD-EF1234567890"
                 Win64="yes">

        <File Id="NSSMExe"
              Name="nssm.exe"
              Source="$(var.SourceDir)resources\nssm.exe"
              KeyPath="yes" />

        <File Id="ARUSServerExe"
              Name="arus-server.exe"
              Source="$(var.SourceDir)resources\arus-server.exe" />

      </Component>
    </DirectoryRef>

    <DirectoryRef Id="APPLICATIONFOLDER">
      <Component Id="ARUSBackendService"
                 Guid="B2C3D4E5-F6A7-8901-BCDE-F12345678901"
                 Win64="yes">

        <RegistryValue Root="HKLM"
                       Key="SOFTWARE\ARUS Marine"
                       Name="BackendServiceInstalled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />

        <util:ServiceConfig
          ServiceName="ARUSBackend"
          FirstFailureActionType="restart"
          SecondFailureActionType="restart"
          ThirdFailureActionType="restart"
          RestartServiceDelayInSeconds="15"
          ResetPeriodInDays="1" />

      </Component>
    </DirectoryRef>

    <!-- ================================================================== -->
    <!-- FRESH INSTALL — Custom Actions                                      -->
    <!-- ================================================================== -->

    <CustomAction Id="CreateARUSDataDir"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c mkdir &quot;[CommonAppDataFolder]ARUS Marine\logs&quot; 2&gt;nul"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Generate a random password and create the service account.
         PowerShell generates a 24-char password, stores it in a temp file,
         creates the user with that password, then deletes the temp file.
         The password is never persisted — NSSM stores it encrypted in the
         registry as part of the service ObjectName configuration.  -->
    <CustomAction Id="CreateARUSServiceAcct"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c powershell -NoProfile -Command &quot;$p = -join ((48..57)+(65..90)+(97..122) | Get-Random -Count 24 | ForEach-Object {[char]$_}); $sp = ConvertTo-SecureString $p -AsPlainText -Force; New-LocalUser -Name 'ARUS_svc' -Password $sp -Description 'ARUS Marine service account' -PasswordNeverExpires -UserMayNotChangePassword -ErrorAction SilentlyContinue; $p | Out-File -Encoding ascii ([IO.Path]::Combine($env:TEMP,'arus_svc_pwd.tmp'))&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Deny interactive logon for the service account -->
    <CustomAction Id="DenyARUSServiceLogon"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c powershell -NoProfile -Command &quot;$sid = (New-Object System.Security.Principal.NTAccount('ARUS_svc')).Translate([System.Security.Principal.SecurityIdentifier]).Value; $tmp = [IO.Path]::GetTempFileName(); secedit /export /cfg $tmp /quiet; $c = Get-Content $tmp; $deny = ($c | Select-String 'SeDenyInteractiveLogonRight').ToString(); if ($deny -notmatch $sid) { $c = $c -replace '(SeDenyInteractiveLogonRight\s*=\s*)', ('$1*' + $sid + ','); $c | Set-Content $tmp; secedit /configure /db ([IO.Path]::ChangeExtension($tmp,'.sdb')) /cfg $tmp /quiet }; Remove-Item $tmp -ErrorAction SilentlyContinue&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="GrantARUSDataDirAccess"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c icacls &quot;[CommonAppDataFolder]ARUS Marine&quot; /grant &quot;ARUS_svc:(OI)(CI)F&quot; /inheritance:e 2&gt;nul"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="InstallARUSService"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; install ARUSBackend &quot;[ARUSBINDIR]arus-server.exe&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Read the temp password file and set the service account -->
    <CustomAction Id="SetServiceAccount"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c for /f &quot;usebackq delims=&quot; %p in (&quot;%TEMP%\arus_svc_pwd.tmp&quot;) do &quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend ObjectName &quot;.\ARUS_svc&quot; &quot;%p&quot; &amp;&amp; del &quot;%TEMP%\arus_svc_pwd.tmp&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <!-- Environment variables — one per NSSM call for robustness -->
    <CustomAction Id="SetServiceEnvPort"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppEnvironmentExtra +PORT=5000"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceEnvNodeEnv"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppEnvironmentExtra +NODE_ENV=production"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceEnvDeployMode"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppEnvironmentExtra +ARUS_DEPLOYMENT_MODE=VESSEL"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceEnvLocalMode"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppEnvironmentExtra +LOCAL_MODE=true"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceEnvDbPath"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppEnvironmentExtra &quot;+DATABASE_PATH=[CommonAppDataFolder]ARUS Marine\vessel-local.db&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceStdout"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppStdout &quot;[CommonAppDataFolder]ARUS Marine\logs\backend.log&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceStderr"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend AppStderr &quot;[CommonAppDataFolder]ARUS Marine\logs\backend-error.log&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceStart"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend Start SERVICE_AUTO_START"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceDisplayName"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend DisplayName &quot;ARUS Marine Backend&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="SetServiceDescription"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; set ARUSBackend Description &quot;ARUS Marine predictive maintenance backend service&quot;"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="InitARUSDatabase"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]arus-server.exe&quot; --init-db"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="StartARUSService"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; start ARUSBackend"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ================================================================== -->
    <!-- UPGRADE — Custom Actions                                            -->
    <!-- ================================================================== -->

    <CustomAction Id="StopARUSServiceUpgrade"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; stop ARUSBackend"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- Run database migration on upgrade to apply any schema changes -->
    <CustomAction Id="MigrateARUSDatabase"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]arus-server.exe&quot; --init-db"
                  Execute="deferred"
                  Impersonate="no"
                  Return="check" />

    <CustomAction Id="RestartARUSService"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; restart ARUSBackend"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ================================================================== -->
    <!-- UNINSTALL — Custom Actions                                          -->
    <!-- ================================================================== -->

    <CustomAction Id="StopARUSService"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; stop ARUSBackend confirm"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveARUSService"
                  Directory="ARUSBINDIR"
                  ExeCommand="&quot;[ARUSBINDIR]nssm.exe&quot; remove ARUSBackend confirm"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <CustomAction Id="RemoveARUSServiceAcct"
                  Directory="ARUSBINDIR"
                  ExeCommand="cmd.exe /c net user ARUS_svc /delete 2&gt;nul"
                  Execute="deferred"
                  Impersonate="no"
                  Return="ignore" />

    <!-- ================================================================== -->
    <!-- Execution Sequence                                                  -->
    <!-- ================================================================== -->

    <InstallExecuteSequence>

      <!-- UPGRADE: stop service before file replacement -->
      <Custom Action="StopARUSServiceUpgrade"
              Before="InstallFiles">Installed AND NOT REMOVE</Custom>

      <!-- FRESH INSTALL: full setup chain -->
      <Custom Action="CreateARUSDataDir"
              After="InstallFiles">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="CreateARUSServiceAcct"
              After="CreateARUSDataDir">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="DenyARUSServiceLogon"
              After="CreateARUSServiceAcct">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="GrantARUSDataDirAccess"
              After="DenyARUSServiceLogon">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="InstallARUSService"
              After="GrantARUSDataDirAccess">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceAccount"
              After="InstallARUSService">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceEnvPort"
              After="SetServiceAccount">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceEnvNodeEnv"
              After="SetServiceEnvPort">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceEnvDeployMode"
              After="SetServiceEnvNodeEnv">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceEnvLocalMode"
              After="SetServiceEnvDeployMode">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceEnvDbPath"
              After="SetServiceEnvLocalMode">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceStdout"
              After="SetServiceEnvDbPath">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceStderr"
              After="SetServiceStdout">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceStart"
              After="SetServiceStderr">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceDisplayName"
              After="SetServiceStart">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="SetServiceDescription"
              After="SetServiceDisplayName">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="InitARUSDatabase"
              After="SetServiceDescription">NOT Installed AND NOT REMOVE</Custom>
      <Custom Action="StartARUSService"
              After="InitARUSDatabase">NOT Installed AND NOT REMOVE</Custom>

      <!-- UPGRADE: migrate database then restart -->
      <Custom Action="MigrateARUSDatabase"
              After="InstallFiles">Installed AND NOT REMOVE</Custom>
      <Custom Action="RestartARUSService"
              After="InstallFinalize">Installed AND NOT REMOVE</Custom>

      <!-- UNINSTALL: stop → remove service → remove account -->
      <Custom Action="StopARUSService"
              Before="RemoveFiles">REMOVE="ALL"</Custom>
      <Custom Action="RemoveARUSService"
              After="StopARUSService">REMOVE="ALL"</Custom>
      <Custom Action="RemoveARUSServiceAcct"
              After="RemoveARUSService">REMOVE="ALL"</Custom>

    </InstallExecuteSequence>

    <Feature Id="ARUSBackendFeature"
             Title="ARUS Backend Service"
             Description="Express.js backend service for ARUS Marine"
             Level="1">
      <ComponentRef Id="ARUSBackendBinaries" />
      <ComponentRef Id="ARUSBackendService" />
    </Feature>

  </Fragment>

</Wix>
