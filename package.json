  "scripts": {
    "dev": "NODE_ENV=development ARUS_DEV_LOGIN=1 tsx server/index.ts",
    "dev:playwright": "tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:renderer": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=server/index.js --allow-overwrite",
    "start": "NODE_ENV=production node dist/index.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build --config src-tauri/tauri.conf.json",
    "tauri:build:desktop": "npm run tauri:build",
    "tauri:build:vessel": "npm run build:sidecar && tauri build --config src-tauri/tauri.vessel.conf.json",
    "tauri:build:cloud": "npm run build:sidecar && tauri build --config src-tauri/tauri.cloud.conf.json",
    "tauri:stage-wix": "node scripts/stage-local-wix.js",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:sidecar:all": "node scripts/build-sidecar.mjs --all",
    "build:sidecar:notest": "node scripts/build-sidecar.mjs --skip-test",
    "generate-icons": "node scripts/generate-icons.mjs",
    "migrate:bcrypt": "node scripts/migrate-bcrypt.mjs",
    "migrate:bcrypt:apply": "node scripts/migrate-bcrypt.mjs --apply",
    "setup:signing": "node scripts/setup-signing.mjs",
    "init-db": "node --input-type=module -e \"import('./server/init-db-entry.js').then(m=>m.initDb())\"",
    "check": "tsc",
    "check:tests": "tsc -p tsconfig.tests.json",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:migrate:status": "tsx server/scripts/migrate.ts --status",
    "db:migrate:deploy": "tsx server/scripts/migrate.ts --deploy",
    "backfill:pdm": "tsx server/scripts/backfill-pdm-permissions.ts",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --forceExit",
    "test:client:hooks": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.client.config.mjs",
    "test:e2e:smoke": "PLAYWRIGHT_LOCAL_BACKEND=1 playwright test --project=chromium --grep @smoke",
    "test:visual": "playwright test --project=visual --project=visual-mobile --project=visual-tablet --grep @visual",
    "test:visual:update": "playwright test --project=visual --project=visual-mobile --project=visual-tablet --grep @visual --update-snapshots",
    "test:stress": "playwright test --project=stress --grep @stress",
    "test:integration": "npm run test:integration:embedded",
    "test:integration:embedded": "node scripts/run-integration-lane.mjs embedded",
    "test:integration:postgres": "node scripts/run-integration-lane.mjs postgres",
    "test:integration:server": "node scripts/run-integration-lane.mjs server",
    "test:integration:legacy": "node scripts/run-integration-lane.mjs legacy",
    "test:forms": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.mjs tests/integration/forms tests/integration/journeys --runInBand",
    "test:all": "npm run test:unit && npm run test:integration",
    "ci": "npm run lint && npm run check && npm run check:guards-full && npm run test:unit && npm run test:client:hooks && npm run test:integration && npm run build",
    "test:coverage": "node --max-old-space-size=8192 --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.coverage.config.mjs --coverage --runInBand",
    "test:coverage:summary": "node --max-old-space-size=8192 --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.coverage.config.mjs --coverage --coverageReporters=text-summary --runInBand",
    "test:load": "node scripts/run-load-test.mjs",
    "test:load:smoke": "node scripts/run-load-test.mjs smoke",
    "test:load:steady": "node scripts/run-load-test.mjs steady",
    "test:load:spike": "node scripts/run-load-test.mjs spike",
    "test:client": "node --experimental-vm-modules node_modules/jest/bin/jest.js client/tests",
    "test:quick": "node client/tests/runner.mjs",
    "test:export": "node client/tests/export.test.mjs",
    "check:schema": "node scripts/validate-dual-schema.mjs",
    "check:route-contract": "node scripts/check-route-contract.mjs",
    "check:api-contracts": "node scripts/check-api-contracts.mjs",
    "check:client-wire-parses": "node scripts/check-client-wire-parses.mjs",
    "check:server-wire-parses": "node scripts/check-server-wire-parses.mjs",
    "check:hex-storage": "node scripts/check-hex-storage-boundaries.mjs",
    "check:drizzle-config": "node scripts/check-drizzle-config.mjs",
    "check:schema-builders": "node scripts/check-schema-builders.mjs",
    "check:rls-coverage": "node scripts/check-rls-coverage.mjs",
    "check:storage-imports": "node scripts/check-storage-imports.mjs",
    "check:schema-imports": "node scripts/check-schema-imports.mjs",
    "check:domain-boundaries": "node scripts/check-domain-boundaries.mjs",
    "check:route-registration": "node scripts/check-route-registration.mjs",
    "check:domain-leaks": "node scripts/check-domain-leaks.mjs",
    "check:ts-burndown": "node scripts/check-ts-burndown.mjs",
    "check:cast-burndown": "node scripts/check-cast-burndown.mjs",
    "check:explicit-any-burndown": "node scripts/check-explicit-any-burndown.mjs",
    "check:lint-warnings": "node scripts/check-lint-warnings.mjs",
    "check:hygiene": "node scripts/hygiene-dashboard.mjs --strict",
    "check:hygiene:report": "node scripts/hygiene-dashboard.mjs",
    "check:boot-health": "node scripts/check-boot-health.mjs",
    "check:stale-types": "node scripts/check-stale-type-names.mjs",
    "check:domain-repositories-imports": "node scripts/check-domain-repositories-imports.mjs",
    "check:dup-types": "node scripts/check-duplicate-domain-types.mjs",
    "check:typed-casts": "node scripts/check-typed-casts.mjs",
    "check:zod-escape": "node scripts/check-zod-escape-hatches.mjs",
    "check:dts-shims": "node scripts/check-dts-shims.mjs",
    "check:eslint-disables": "node scripts/check-eslint-disables.mjs",
    "check:dead-code": "node scripts/check-knip.mjs",
    "check:contract-ratchets": "npm run check:api-contracts && npm run check:client-wire-parses && npm run check:server-wire-parses && npm run check:route-contract && npm run check:hex-storage",
    "check:duplication": "jscpd --config .jscpd.json",
    "check:type-debt": "npm run check:dup-types && npm run check:typed-casts && npm run check:zod-escape && npm run check:dts-shims && npm run check:eslint-disables",
    "check:envelope-adoption": "node scripts/check-envelope-adoption.mjs",
    "check:raw-fetch": "node scripts/check-raw-fetch.mjs",
    "check:ui-ratchets": "node scripts/check-ui-ratchets.mjs",
    "check:anti-placeholder": "node scripts/check-anti-placeholder.mjs",
    "check:dynamic-classnames": "node scripts/check-dynamic-classnames.mjs",
    "check:scheduler-single-flight": "node scripts/check-scheduler-single-flight.mjs",
    "check:guards": "npm run check:schema && npm run check:drizzle-config && npm run check:schema-builders && npm run check:rls-coverage && npm run check:storage-imports && npm run check:schema-imports && npm run check:domain-boundaries && npm run check:route-registration && npm run check:domain-leaks && npm run check:stale-types && npm run check:org-context && npm run check:workflow-routes && npm run check:operator-experience-architecture && npm run check:domain-repositories-imports && npm run check:deploy-image && npm run check:type-debt && npm run check:envelope-adoption && npm run check:raw-fetch && npm run check:tsconfig-target && npm run check:ui-ratchets && npm run check:anti-placeholder && npm run check:dynamic-classnames && npm run check:scheduler-single-flight",
    "check:guards-full": "npm run check:guards && npm run check:ts-burndown && npm run check:tests && npm run check:cast-burndown && npm run check:explicit-any-burndown && npm run check:lint-warnings && npm run check:hygiene && npm run check:boot-health && npm run format:check && npm run check:dead-code && npm run check:contract-ratchets",
    "check:debt-zero": "npm run check:guards-full",
    "test:validation": "node client/tests/validation.test.mjs",
    "test:stcw": "node client/tests/stcw.test.mjs",
    "test:dates": "node client/tests/dates.test.mjs",
    "test:dual-db": "npx jest tests/unit/dual-schema-smoke.test.ts tests/unit/dual-driver-query-parity.test.ts tests/unit/idempotency-dual-driver.test.ts --forceExit",
    "test:pdm": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm' --testPathIgnorePatterns='schedule-properties'",
    "test:pdm:tier0": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm' --testPathIgnorePatterns='schedule-properties'",
    "test:pdm:tier1": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm/schedule-properties'",
    "check:tsconfig-target": "node scripts/check-tsconfig-target.mjs",
    "check:org-context": "node scripts/check-org-context-boundary.mjs",
    "check:workflow-routes": "node scripts/check-workflow-routes.mjs",
    "test:pdm:decision-support": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.pdm-decision-support.config.mjs --runInBand",
    "test:operator-experience": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/operator-experience-service.test.ts tests/unit/operator-information-needs-service.test.ts tests/integration/operator-experience-routes.test.ts tests/integration/operator-information-needs-routes.test.ts --runInBand",
    "test:operator-information-needs": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/operator-information-needs-service.test.ts tests/integration/operator-information-needs-routes.test.ts --runInBand",
    "check:operator-experience-architecture": "node scripts/check-operator-experience-architecture.mjs",
    "check:deploy-image": "node scripts/check-deploy-image-guard.mjs",
    "report:route-permission-matrix": "node scripts/generate-route-permission-matrix.mjs"
  },
