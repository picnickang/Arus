{
  "name": "arus-maritime-pdm",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "NODE_ENV=development tsx server/index.ts",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:renderer": "vite build",
    "build:server": "esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=server/index.js --allow-overwrite",
    "start": "NODE_ENV=production node dist/index.js",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build",
    "tauri:build:vessel": "npm run build:sidecar && tauri build --config src-tauri/tauri.vessel.conf.json",
    "tauri:build:cloud": "npm run build:sidecar && tauri build --config src-tauri/tauri.cloud.conf.json",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "build:sidecar:all": "node scripts/build-sidecar.mjs --all",
    "build:sidecar:notest": "node scripts/build-sidecar.mjs --skip-test",
    "generate-icons": "node scripts/generate-icons.mjs",
    "migrate:bcrypt": "node scripts/migrate-bcrypt.mjs",
    "migrate:bcrypt:apply": "node scripts/migrate-bcrypt.mjs --apply",
    "setup:signing": "node scripts/setup-signing.mjs",
    "init-db": "node --input-type=module -e \"import('./server/init-db-entry.js').then(m=>m.initDb())\"",
    "check": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write . --cache",
    "format:check": "prettier --check . --cache",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/scripts/migrate.ts",
    "db:migrate:status": "tsx server/scripts/migrate.ts --status",
    "db:migrate:deploy": "tsx server/scripts/migrate.ts --deploy",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:unit": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit --forceExit",
    "test:integration": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.mjs --runInBand",
    "test:forms": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.integration.config.mjs tests/integration/forms tests/integration/journeys --runInBand",
    "test:all": "npm run test:unit && npm run test:integration",
    "ci": "npm run lint && npm run check:guards && npm run check && npm run test:unit && npm run test:integration && npm run build",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "test:client": "node --experimental-vm-modules node_modules/jest/bin/jest.js client/tests",
    "test:quick": "node client/tests/runner.mjs",
    "test:export": "node client/tests/export.test.mjs",
    "check:schema": "node scripts/validate-dual-schema.mjs",
    "check:storage-imports": "node scripts/check-storage-imports.mjs",
    "check:schema-imports": "node scripts/check-schema-imports.mjs",
    "check:domain-boundaries": "node scripts/check-domain-boundaries.mjs",
    "check:route-registration": "node scripts/check-route-registration.mjs",
    "check:domain-leaks": "node scripts/check-domain-leaks.mjs",
    "check:ts-burndown": "node scripts/check-ts-burndown.mjs",
    "check:cast-burndown": "node scripts/check-cast-burndown.mjs",
    "check:lint-warnings": "node scripts/check-lint-warnings.mjs",
    "check:hygiene": "node scripts/hygiene-dashboard.mjs --strict",
    "check:hygiene:report": "node scripts/hygiene-dashboard.mjs",
    "check:boot-health": "node scripts/check-boot-health.mjs",
    "check:stale-types": "node scripts/check-stale-type-names.mjs",
    "check:domain-repositories-imports": "node scripts/check-domain-repositories-imports.mjs",
    "check:guards": "npm run check:schema && npm run check:storage-imports && npm run check:schema-imports && npm run check:domain-boundaries && npm run check:route-registration && npm run check:domain-leaks && npm run check:stale-types && npm run check:org-context && npm run check:workflow-routes && npm run check:operator-experience-architecture && npm run check:domain-repositories-imports",
    "check:guards-full": "npm run check:guards && npm run check:ts-burndown && npm run check:cast-burndown && npm run check:lint-warnings && npm run check:hygiene && npm run check:boot-health && npm run format:check",
    "test:validation": "node client/tests/validation.test.mjs",
    "test:stcw": "node client/tests/stcw.test.mjs",
    "test:dates": "node client/tests/dates.test.mjs",
    "test:dual-db": "npx jest tests/unit/dual-schema-smoke.test.ts tests/unit/dual-driver-query-parity.test.ts --forceExit",
    "test:pdm": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm' --testPathIgnorePatterns='schedule-properties'",
    "test:pdm:tier0": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm' --testPathIgnorePatterns='schedule-properties'",
    "test:pdm:tier1": "node --experimental-vm-modules node_modules/jest/bin/jest.js --testPathPatterns='server/tests/pdm/schedule-properties'",
    "check:org-context": "node scripts/check-org-context-boundary.mjs",
    "check:workflow-routes": "node scripts/check-workflow-routes.mjs",
    "test:pdm:decision-support": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.pdm-decision-support.config.mjs --runInBand",
    "test:operator-experience": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/operator-experience-service.test.ts tests/unit/operator-information-needs-service.test.ts tests/integration/operator-experience-routes.test.ts tests/integration/operator-information-needs-routes.test.ts --runInBand",
    "test:operator-information-needs": "node --experimental-vm-modules node_modules/jest/bin/jest.js tests/unit/operator-information-needs-service.test.ts tests/integration/operator-information-needs-routes.test.ts --runInBand",
    "check:operator-experience-architecture": "node scripts/check-operator-experience-architecture.mjs"
  },
