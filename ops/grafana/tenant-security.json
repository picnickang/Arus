{
  "title": "ARUS — Tenant Security & Isolation",
  "uid": "arus-tenant-security",
  "schemaVersion": 38,
  "tags": ["arus", "tenant", "security"],
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "1m",
  "templating": {
    "list": [
      { "name": "datasource", "type": "datasource", "query": "prometheus" },
      { "name": "org", "type": "query", "datasource": "${datasource}", "query": "label_values(arus_websocket_connections_active_per_org, org_id)", "includeAll": true }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Per-org WS connections (gauge)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "arus_websocket_connections_active_per_org{org_id=~\"$org\"}", "legendFormat": "{{org_id}}" }
      ]
    },
    {
      "id": 2,
      "title": "WS rejections by reason",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (org_id, reason) (rate(arus_websocket_connections_rejected_total{org_id=~\"$org\"}[5m]))", "legendFormat": "{{org_id}}::{{reason}}" }
      ]
    },
    {
      "id": 3,
      "title": "Telemetry quota-blocked rows / sec",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum by (org_id) (rate(arus_telemetry_batch_quota_blocked_total{org_id=~\"$org\"}[5m]))", "legendFormat": "{{org_id}}" }
      ]
    },
    {
      "id": 4,
      "title": "HTTP 429 rate (fleet-wide — http-metrics has no org_id label today)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "sum(rate(arus_http_requests_total{code=\"429\"}[5m]))", "legendFormat": "429/sec" }
      ]
    },
    {
      "id": 5,
      "title": "API response validation failures by route",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "targets": [
        { "expr": "sum by (route) (rate(arus_api_response_validation_failures_total[15m]))", "legendFormat": "{{route}}" }
      ]
    }
  ]
}
