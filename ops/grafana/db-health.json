{
  "title": "ARUS — Database Health",
  "uid": "arus-db-health",
  "schemaVersion": 38,
  "tags": ["arus", "db", "postgres"],
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [ { "name": "datasource", "type": "datasource", "query": "prometheus" } ] },
  "panels": [
    {
      "id": 1,
      "title": "Node.js process RSS (MB)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [ { "expr": "process_resident_memory_bytes / 1024 / 1024", "legendFormat": "rss" } ]
    },
    {
      "id": 2,
      "title": "HTTP request rate by route (writes only)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [ { "expr": "sum by (route, method) (rate(arus_http_requests_total{method=~\"POST|PUT|PATCH|DELETE\"}[5m]))", "legendFormat": "{{method}} {{route}}" } ]
    },
    {
      "id": 3,
      "title": "HTTP duration p95 (s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, sum by (le, route) (rate(arus_http_request_duration_seconds_bucket[5m])))", "legendFormat": "{{route}}" }
      ]
    },
    {
      "id": 4,
      "title": "Event-loop lag p99 (s)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [ { "expr": "histogram_quantile(0.99, sum by (le) (rate(nodejs_eventloop_lag_seconds_bucket[5m])))", "legendFormat": "p99" } ]
    }
  ]
}
